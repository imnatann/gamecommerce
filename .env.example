APP_NAME=GameCommerce
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=gamecommerce
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
CACHE_PREFIX=gamecommerce_

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

# Mail
MAIL_MAILER=smtp
MAIL_SCHEME=https
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@gamecommerce.id"
MAIL_FROM_NAME="${APP_NAME}"
MAIL_ENCRYPTION=tls

# Midtrans
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false
MIDTRANS_IS_SANITIZED=true
MIDTRANS_IS_3DS=true
MIDTRANS_APPEND_NOTIF_URL=
MIDTRANS_OVERRIDE_NOTIF_URL=

# Xendit
XENDIT_SECRET_KEY=
XENDIT_PUBLIC_KEY=
XENDIT_WEBHOOK_SECRET=
XENDIT_IS_PRODUCTION=false

# Payment
PAYMENT_GATEWAY=midtrans

# GameCommerce
GAMECOMMERCE_PRODUCTS_PER_PAGE=24
GAMECOMMERCE_MAX_UPLOAD_SIZE=5120
GAMECOMMERCE_COMMISSION_RATE=5
GAMECOMMERCE_PREMIUM_COMMISSION_RATE=3
GAMECOMMERCE_BOOSTING_COMMISSION_RATE=8
GAMECOMMERCE_MIN_WITHDRAWAL=50000
GAMECOMMERCE_ORDER_EXPIRY_MINUTES=30
GAMECOMMERCE_AUTO_COMPLETE_DAYS=3
GAMECOMMERCE_DISPUTE_WINDOW_HOURS=24
GAMECOMMERCE_CACHE_TTL_GAMES=3600
GAMECOMMERCE_CACHE_TTL_PRODUCTS=1800
GAMECOMMERCE_CACHE_TTL_CATEGORIES=7200
GAMECOMMERCE_CACHE_TTL_BANNERS=1800
GAMECOMMERCE_CACHE_TTL_SEARCH=900
GAMECOMMERCE_STORAGE_DISK=local

# Meilisearch
MEILISEARCH_HOST=http://127.0.0.1:7700
MEILISEARCH_KEY=
MEILISEARCH_INDEX_PREFIX=gamecommerce_

# AWS / S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-southeast-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Reverb (WebSocket)
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

# Vite
VITE_APP_NAME="${APP_NAME}"

# Auth
AUTH_GUARD=web
AUTH_PASSWORD_BROKER=users
AUTH_PASSWORD_TIMEOUT=10800